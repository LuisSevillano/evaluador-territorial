{
	"name": "el-buen-vivir-frontend",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:with-docs": "rm -rf build && npm run build && npm run docs:build && npm run docs:sync",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"docs:build": "npm --prefix ../docs-site run docs:build",
		"docs:sync": "rm -rf build/docs && mkdir -p build/docs && cp -R ../docs-site/.vitepress/dist/. build/docs/",
		"deploy": "npm run build:with-docs && netlify deploy --prod"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"svelte": "^5.2.0",
		"svelte-check": "^4.0.7",
		"typescript": "^5.6.3",
		"vite": "^5.4.8"
	},
	"dependencies": {
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-format": "^3.1.2",
		"d3-interpolate": "^3.0.1",
		"d3-scale": "^4.0.2",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"lucide-svelte": "^1.0.1",
		"maplibre-gl": "^5.0.0",
		"pmtiles": "^4.3.0"
	}
}
