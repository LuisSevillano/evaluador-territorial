node_modules/
.svelte-kit/
build/
dist/
.DS_Store
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
data/intermediate/*
data/output/*
data/output/parquet/*
data/output/pmtiles/*
data/raw/*
data/temp/*
output/*
!data/intermediate/.gitkeep
!data/output/.gitkeep
!data/output/parquet/.gitkeep
!data/output/pmtiles/.gitkeep

# Block heavy geospatial artifacts everywhere by default
*.pmtiles
*.mbtiles
*.gpkg
*.fgb
*.shp
*.dbf
*.shx
*.prj
*.cpg
*.tif
*.tiff
*.gpkg-wal
*.gpkg-shm

# Keep only frontend runtime tiles versioned
!frontend/static/tiles/
!frontend/static/tiles/*.pmtiles

# Local Netlify folder
.netlify

# Frontend uses PMTiles; avoid committing heavy GeoJSON artifacts
frontend/static/data/*.geojson
